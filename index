<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Time to Order</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
 
  :root {
    --accent: #D85A30;
    --accent-bg: #FAECE7;
    --accent-text: #993C1D;
    --green: #1D9E75;
    --green-bg: #E1F5EE;
    --green-text: #0F6E56;
    --bg: #faf9f7;
    --surface: #ffffff;
    --surface2: #f1efe8;
    --border: rgba(0,0,0,0.1);
    --border2: rgba(0,0,0,0.18);
    --text: #1a1a18;
    --text2: #5f5e5a;
    --text3: #9a9890;
    --radius: 10px;
    --radius-sm: 7px;
  }
 
  body {
    font-family: 'Georgia', serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
  }
 
  /* ── Admin corner button ── */
  #admin-corner-btn {
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 100;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--surface2);
    border: 0.5px solid var(--border2);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }
  #admin-corner-btn:hover { background: #e4e2da; }
  #admin-corner-btn svg { width: 15px; height: 15px; color: var(--text2); }
 
  /* ── Pages ── */
  .page { display: none; }
  .page.active { display: block; }
 
  /* ── Login modal overlay ── */
  #login-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.35);
    z-index: 200;
    align-items: center;
    justify-content: center;
  }
  #login-overlay.show { display: flex; }
  .login-box {
    background: var(--surface);
    border-radius: var(--radius);
    border: 0.5px solid var(--border2);
    padding: 2rem;
    width: 320px;
    max-width: 90vw;
  }
  .login-box h3 { font-size: 17px; font-weight: normal; margin-bottom: 6px; color: var(--text); }
  .login-box p { font-size: 13px; color: var(--text2); margin-bottom: 1.2rem; font-family: sans-serif; }
  .login-box input {
    width: 100%;
    font-size: 14px;
    padding: 9px 12px;
    border: 0.5px solid var(--border2);
    border-radius: var(--radius-sm);
    background: var(--bg);
    color: var(--text);
    font-family: sans-serif;
    margin-bottom: 10px;
  }
  .login-box input:focus { outline: none; border-color: var(--accent); }
  .login-error { font-size: 12px; color: #A32D2D; font-family: sans-serif; margin-bottom: 8px; display: none; }
  .login-actions { display: flex; gap: 8px; }
  .btn-primary {
    flex: 1; padding: 9px; background: var(--accent); color: #fff;
    border: none; border-radius: var(--radius-sm); font-size: 13px;
    cursor: pointer; font-family: sans-serif;
  }
  .btn-primary:hover { opacity: 0.9; }
  .btn-ghost {
    padding: 9px 14px; background: transparent; color: var(--text2);
    border: 0.5px solid var(--border2); border-radius: var(--radius-sm);
    font-size: 13px; cursor: pointer; font-family: sans-serif;
  }
  .btn-ghost:hover { background: var(--surface2); }
 
  /* ── Shared layout ── */
  .container { max-width: 680px; margin: 0 auto; padding: 2rem 1.25rem 5rem; }
 
  /* ── Order form styles ── */
  .hero { text-align: center; margin-bottom: 2.5rem; }
  .hero h1 { font-size: 32px; font-weight: normal; letter-spacing: -0.5px; color: var(--text); margin-bottom: 8px; }
  .hero p { font-size: 14px; color: var(--text2); line-height: 1.6; font-family: sans-serif; }
 
  .section-label {
    font-size: 10px; font-weight: bold; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--text3);
    margin: 0 0 12px; font-family: sans-serif;
  }
 
  .new-arrivals-grid, .brand-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 10px;
  }
  .new-arrivals-grid { margin-bottom: 2rem; }
  .brand-block { margin-bottom: 2rem; }
  .brand-title {
    font-size: 12px; font-weight: bold; letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--text2);
    padding: 5px 0; border-bottom: 0.5px solid var(--border);
    margin-bottom: 10px; font-family: sans-serif;
  }
 
  .item-card {
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: var(--radius);
    padding: 12px;
    cursor: pointer;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .item-card:hover:not(.out-of-stock) { border-color: var(--border2); }
  .item-card.selected { border: 1.5px solid var(--accent); background: var(--accent-bg); }
  .item-card.out-of-stock { opacity: 0.45; cursor: not-allowed; background: var(--surface2); }
 
  .item-emoji { font-size: 26px; display: block; margin-bottom: 8px; }
  .item-name { font-size: 13px; font-weight: bold; color: var(--text); margin: 0 0 2px; font-family: sans-serif; }
  .item-desc { font-size: 11px; color: var(--text2); margin: 0 0 6px; line-height: 1.4; font-family: sans-serif; }
  .item-price { font-size: 13px; color: var(--accent-text); font-family: sans-serif; }
 
  .new-badge, .low-badge, .out-badge {
    display: inline-block; font-size: 10px; font-weight: bold;
    padding: 2px 6px; border-radius: 20px; margin-bottom: 5px;
    font-family: sans-serif; letter-spacing: 0.03em;
  }
  .new-badge { background: #FAEEDA; color: #633806; }
  .low-badge { background: #FAEEDA; color: #633806; margin-top: 4px; margin-bottom: 0; }
  .out-badge { background: #FCEBEB; color: #791F1F; margin-top: 4px; margin-bottom: 0; }
 
  .qty-ctrl { display: flex; align-items: center; gap: 7px; margin-top: 9px; }
  .qty-btn {
    width: 24px; height: 24px;
    border: 0.5px solid var(--border2);
    background: var(--surface2);
    border-radius: 50%; font-size: 15px;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    color: var(--text); line-height: 1; font-family: sans-serif;
  }
  .qty-btn:hover { background: #e4e2da; }
  .qty-btn:disabled { opacity: 0.3; cursor: not-allowed; }
  .qty-num { font-size: 13px; font-weight: bold; min-width: 16px; text-align: center; color: var(--text); font-family: sans-serif; }
 
  .option-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 1.5rem; }
  .option-card {
    border: 0.5px solid var(--border2); border-radius: var(--radius-sm);
    padding: 11px 13px; cursor: pointer; background: var(--surface); transition: border-color 0.15s;
  }
  .option-card:hover { border-color: var(--text3); }
  .option-card.selected { border: 1.5px solid var(--accent); background: var(--accent-bg); }
  .option-card .opt-title { font-size: 13px; font-weight: bold; color: var(--text); margin: 0 0 2px; font-family: sans-serif; }
  .option-card .opt-sub { font-size: 11px; color: var(--text2); margin: 0; font-family: sans-serif; }
  .option-card.selected .opt-title { color: var(--accent-text); }
 
  .delivery-notice {
    font-size: 13px; padding: 9px 13px; border-radius: var(--radius-sm);
    margin-bottom: 1.5rem; display: flex; align-items: center; gap: 8px;
    font-family: sans-serif;
  }
  .delivery-notice.free { background: var(--green-bg); color: var(--green-text); }
  .delivery-notice.paid { background: var(--accent-bg); color: var(--accent-text); }
  .delivery-notice.hidden { display: none; }
  .progress-bar-wrap { background: rgba(0,0,0,0.08); border-radius: 20px; height: 5px; margin: 5px 0 0; overflow: hidden; }
  .progress-bar { height: 5px; border-radius: 20px; background: var(--green); transition: width 0.3s; }
 
  .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 1.5rem; }
  .field { display: flex; flex-direction: column; gap: 5px; }
  .field.full { grid-column: 1 / -1; }
  .field label { font-size: 12px; color: var(--text2); font-family: sans-serif; }
  .field input, .field textarea {
    font-size: 13px; padding: 8px 10px;
    border: 0.5px solid var(--border2); border-radius: var(--radius-sm);
    background: var(--surface); color: var(--text); font-family: sans-serif;
  }
  .field input:focus, .field textarea:focus { outline: none; border-color: var(--accent); }
  .field textarea { resize: vertical; min-height: 68px; }
 
  .phone-wrap {
    display: flex; align-items: stretch;
    border: 0.5px solid var(--border2); border-radius: var(--radius-sm); overflow: hidden;
    background: var(--surface);
  }
  .phone-prefix {
    padding: 8px 10px; font-size: 13px; color: var(--text2);
    background: var(--surface2); border-right: 0.5px solid var(--border2);
    white-space: nowrap; display: flex; align-items: center;
    user-select: none; font-family: sans-serif;
  }
  .phone-wrap input { border: none; border-radius: 0; flex: 1; min-width: 0; background: transparent; font-size: 13px; font-family: sans-serif; color: var(--text); }
  .phone-wrap input:focus { outline: none; }
 
  .summary-card { background: var(--surface2); border-radius: var(--radius); padding: 1rem 1.1rem; margin-bottom: 1.5rem; }
  .summary-row { display: flex; justify-content: space-between; font-size: 13px; padding: 3px 0; color: var(--text); font-family: sans-serif; }
  .summary-row.muted { color: var(--text2); }
  .summary-row.free-delivery { color: var(--green-text); }
  .summary-row.total { font-weight: bold; font-size: 14px; border-top: 0.5px solid var(--border2); padding-top: 9px; margin-top: 6px; }
  .empty-note { font-size: 13px; color: var(--text3); font-style: italic; font-family: sans-serif; }
 
  .dot { width: 7px; height: 7px; border-radius: 50%; display: inline-block; flex-shrink: 0; }
  .dot.green { background: var(--green); }
  .dot.orange { background: var(--accent); }
 
  .wa-btn {
    width: 100%; padding: 13px; background: #25D366; border: none;
    border-radius: var(--radius); font-size: 14px; font-weight: bold;
    color: #fff; cursor: pointer; display: flex; align-items: center;
    justify-content: center; gap: 8px; transition: opacity 0.15s; font-family: sans-serif;
  }
  .wa-btn:hover { opacity: 0.92; }
  .wa-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .wa-icon { width: 18px; height: 18px; flex-shrink: 0; }
 
  /* ── Admin panel styles ── */
  .admin-topbar {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 1.5rem; flex-wrap: wrap; gap: 10px;
  }
  .admin-topbar h2 { font-size: 22px; font-weight: normal; color: var(--text); }
  .admin-back-btn {
    font-size: 12px; padding: 7px 14px;
    border: 0.5px solid var(--border2); border-radius: var(--radius-sm);
    background: var(--surface); color: var(--text2);
    cursor: pointer; font-family: sans-serif; display: flex; align-items: center; gap: 5px;
  }
  .admin-back-btn:hover { background: var(--surface2); }
 
  .stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 1.5rem; }
  .stat { background: var(--surface2); border-radius: var(--radius-sm); padding: 12px 14px; }
  .stat-label { font-size: 11px; color: var(--text3); margin-bottom: 4px; font-family: sans-serif; }
  .stat-val { font-size: 24px; font-weight: normal; color: var(--text); font-family: 'Georgia', serif; }
  .stat-val.warn { color: #854F0B; }
  .stat-val.danger { color: #A32D2D; }
 
  .thresh-row {
    display: flex; align-items: center; gap: 10px;
    margin-bottom: 1.5rem; flex-wrap: wrap;
  }
  .thresh-row label { font-size: 13px; color: var(--text2); font-family: sans-serif; }
  .thresh-row input {
    width: 56px; font-size: 13px; padding: 5px 8px;
    border: 0.5px solid var(--border2); border-radius: var(--radius-sm);
    background: var(--surface); color: var(--text); text-align: center; font-family: sans-serif;
  }
  .thresh-row input:focus { outline: none; border-color: var(--accent); }
 
  .admin-brand-block { margin-bottom: 1.5rem; }
  .admin-brand-name {
    font-size: 11px; font-weight: bold; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--text3);
    padding: 5px 0; border-bottom: 0.5px solid var(--border);
    margin-bottom: 8px; font-family: sans-serif;
  }
  .product-row {
    display: flex; align-items: center; gap: 10px;
    padding: 8px 0; border-bottom: 0.5px solid var(--border);
    flex-wrap: wrap;
  }
  .product-row:last-child { border-bottom: none; }
  .prod-emoji { font-size: 15px; flex-shrink: 0; }
  .prod-info { flex: 1; min-width: 110px; }
  .prod-name { font-size: 13px; font-weight: bold; color: var(--text); font-family: sans-serif; }
  .prod-price { font-size: 11px; color: var(--text3); font-family: sans-serif; }
  .stock-ctrl { display: flex; align-items: center; gap: 7px; }
  .stock-input {
    width: 58px; font-size: 13px; padding: 5px 7px;
    border: 0.5px solid var(--border2); border-radius: var(--radius-sm);
    background: var(--surface); color: var(--text); text-align: center; font-family: sans-serif;
  }
  .stock-input:focus { outline: none; border-color: var(--accent); }
  .stock-badge { font-size: 11px; padding: 2px 8px; border-radius: 20px; font-weight: bold; white-space: nowrap; font-family: sans-serif; }
  .badge-ok { background: #EAF3DE; color: #27500A; }
  .badge-low { background: #FAEEDA; color: #633806; }
  .badge-out { background: #FCEBEB; color: #791F1F; }
 
  .save-all-btn {
    font-size: 13px; padding: 9px 18px;
    border: 0.5px solid var(--border2); border-radius: var(--radius-sm);
    background: var(--surface); color: var(--text); cursor: pointer; font-family: sans-serif;
  }
  .save-all-btn:hover { background: var(--surface2); }
  .toast {
    font-size: 12px; padding: 6px 12px; background: var(--surface2);
    border: 0.5px solid var(--border2); border-radius: var(--radius-sm);
    color: var(--text2); display: none; font-family: sans-serif;
  }
  .new-section-wrap { background: var(--surface2); border-radius: var(--radius-sm); padding: 4px 8px; margin-bottom: 1.5rem; }
</style>
</head>
<body>
 
<!-- Admin corner button (always visible) -->
<button id="admin-corner-btn" title="Admin" onclick="showLogin()">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
  </svg>
</button>
 
<!-- Login overlay -->
<div id="login-overlay">
  <div class="login-box">
    <h3>Admin access</h3>
    <p>Enter your password to manage inventory.</p>
    <input type="password" id="pw-input" placeholder="Password" onkeydown="if(event.key==='Enter')tryLogin()">
    <p class="login-error" id="login-error">Incorrect password. Try again.</p>
    <div class="login-actions">
      <button class="btn-ghost" onclick="closeLogin()">Cancel</button>
      <button class="btn-primary" onclick="tryLogin()">Enter</button>
    </div>
  </div>
</div>
 
<!-- ORDER FORM PAGE -->
<div id="page-order" class="page active">
  <div class="container">
    <div class="hero">
      <h1>Time to Order</h1>
      <p>Classic and trending snacks, handpicked for modern taste buds!</p>
    </div>
 
    <p class="section-label">New Arrivals</p>
    <div class="new-arrivals-grid" id="new-arrivals"></div>
 
    <p class="section-label">Product Selection</p>
    <div id="brand-catalog"></div>
 
    <p class="section-label">Delivery method</p>
    <div class="option-grid">
      <div class="option-card selected" data-delivery="delivery" onclick="selectDelivery('delivery')">
        <p class="opt-title">Delivery</p>
        <p class="opt-sub">$3.00 fee · free above $30</p>
      </div>
      <div class="option-card" data-delivery="pickup" onclick="selectDelivery('pickup')">
        <p class="opt-title">Self-pickup</p>
        <p class="opt-sub">No extra charge</p>
      </div>
    </div>
    <div class="delivery-notice hidden" id="delivery-notice">
      <span class="dot" id="notice-dot"></span>
      <span id="notice-text"></span>
    </div>
 
    <p class="section-label">Payment method</p>
    <div class="option-grid">
      <div class="option-card selected" data-pay="paynow" onclick="selectPayment('paynow')"><p class="opt-title">PayNow</p><p class="opt-sub">UEN / phone number</p></div>
      <div class="option-card" data-pay="cash" onclick="selectPayment('cash')"><p class="opt-title">Cash on delivery</p><p class="opt-sub">Pay when you receive</p></div>
      <div class="option-card" data-pay="transfer" onclick="selectPayment('transfer')"><p class="opt-title">Bank transfer</p><p class="opt-sub">DBS / OCBC / UOB</p></div>
      <div class="option-card" data-pay="grabpay" onclick="selectPayment('grabpay')"><p class="opt-title">GrabPay</p><p class="opt-sub">Scan QR to pay</p></div>
    </div>
 
    <p class="section-label">Your details</p>
    <div class="info-grid">
      <div class="field full"><label>Full name / Company name</label><input type="text" id="f-name" placeholder="e.g. Sarah Tan or Acme Pte Ltd"></div>
      <div class="field full"><label>Phone number</label>
        <div class="phone-wrap"><span class="phone-prefix">+65</span><input type="tel" id="f-phone" placeholder="9123 4567" maxlength="8"></div>
      </div>
      <div class="field full" id="address-field"><label>Delivery address</label><input type="text" id="f-address" placeholder="Block, street, unit number"></div>
      <div class="field full"><label>Notes (optional)</label><textarea id="f-notes" placeholder="Allergies, special requests…"></textarea></div>
    </div>
 
    <p class="section-label">Order summary</p>
    <div class="summary-card">
      <div id="summary-lines"><p class="empty-note">No items selected yet.</p></div>
      <div id="delivery-fee-row" class="summary-row muted" style="display:none"></div>
      <div class="summary-row total" id="total-row" style="display:none"><span>Total</span><span id="total-amount">$0.00</span></div>
    </div>
 
    <button class="wa-btn" id="wa-btn" disabled>
      <svg class="wa-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      Send order via WhatsApp
    </button>
  </div>
</div>
 
<!-- ADMIN PAGE -->
<div id="page-admin" class="page">
  <div class="container">
    <div class="admin-topbar">
      <h2>Inventory admin</h2>
      <div style="display:flex;gap:8px;align-items:center;">
        <span class="toast" id="toast"></span>
        <button class="save-all-btn" onclick="saveAll()">Save all changes</button>
        <button class="admin-back-btn" onclick="goToOrder()">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
          Back to store
        </button>
      </div>
    </div>
 
    <div class="stats">
      <div class="stat"><p class="stat-label">Total products</p><p class="stat-val" id="stat-total">—</p></div>
      <div class="stat"><p class="stat-label">Low stock</p><p class="stat-val warn" id="stat-low">—</p></div>
      <div class="stat"><p class="stat-label">Out of stock</p><p class="stat-val danger" id="stat-out">—</p></div>
    </div>
 
    <div class="thresh-row">
      <p class="section-label" style="margin:0;">Low stock threshold</p>
      <label>Flag as low when stock ≤</label>
      <input type="number" id="low-thresh" value="5" min="1" max="99" onchange="renderAdmin()">
      <span style="font-size:13px;color:var(--text2);">units</span>
    </div>
 
    <p class="section-label">New arrivals</p>
    <div class="new-section-wrap" id="admin-new"></div>
 
    <p class="section-label">Product selection</p>
    <div id="admin-brands"></div>
  </div>
</div>
 
<script>
const ADMIN_PASSWORD = 'admin123';
const LOW_THRESH_DEFAULT = 5;
const DELIVERY_FEE = 3.00;
const FREE_THRESHOLD = 30.00;
const WA_NUMBER = '6591234567';
 
const NEW_ARRIVALS = [
  { id: 'n1', emoji: '🍬', name: 'Placeholder Drop A', desc: 'Coming soon — stay tuned!', price: 3.50 },
  { id: 'n2', emoji: '🍫', name: 'Placeholder Drop B', desc: 'Coming soon — stay tuned!', price: 4.00 },
  { id: 'n3', emoji: '🍭', name: 'Placeholder Drop C', desc: 'Coming soon — stay tuned!', price: 3.00 },
];
const BRANDS = [
  { brand: 'Airheads', products: [
    { id: 'a1', emoji: '🍬', name: 'Airheads Bars', desc: 'Chewy taffy candy bar, assorted flavours', price: 2.50 },
    { id: 'a2', emoji: '🍡', name: 'Airheads Bites', desc: 'Bite-sized soft & chewy candy pieces', price: 3.00 },
  ]},
  { brand: 'Nerds', products: [
    { id: 'nb1', emoji: '🍇', name: 'Nerds Grape & Strawberry', desc: 'Tiny crunchy candy, two flavours in one box', price: 2.80 },
    { id: 'nb2', emoji: '🌈', name: 'Nerds Rope Rainbow', desc: 'Chewy rope covered in rainbow Nerds', price: 3.20 },
  ]},
];
const ALL_PRODUCTS = [...NEW_ARRIVALS, ...BRANDS.flatMap(b => b.products)];
 
let stock = {};
let qty = {};
ALL_PRODUCTS.forEach(p => qty[p.id] = 0);
let deliveryMethod = 'delivery';
let paymentMethod = 'paynow';
 
function loadStock() {
  try {
    const saved = localStorage.getItem('inventory-stock');
    stock = saved ? JSON.parse(saved) : {};
  } catch(e) { stock = {}; }
  ALL_PRODUCTS.forEach(p => { if (stock[p.id] === undefined) stock[p.id] = 20; });
}
 
function saveStock() {
  try { localStorage.setItem('inventory-stock', JSON.stringify(stock)); } catch(e) {}
}
 
function getThresh() {
  const el = document.getElementById('low-thresh');
  return el ? (parseInt(el.value) || LOW_THRESH_DEFAULT) : LOW_THRESH_DEFAULT;
}
 
/* ── Login ── */
function showLogin() {
  document.getElementById('login-overlay').classList.add('show');
  document.getElementById('pw-input').value = '';
  document.getElementById('login-error').style.display = 'none';
  setTimeout(() => document.getElementById('pw-input').focus(), 50);
}
function closeLogin() {
  document.getElementById('login-overlay').classList.remove('show');
}
function tryLogin() {
  const val = document.getElementById('pw-input').value;
  if (val === ADMIN_PASSWORD) {
    closeLogin();
    showPage('admin');
    renderAdmin();
  } else {
    document.getElementById('login-error').style.display = 'block';
    document.getElementById('pw-input').value = '';
    document.getElementById('pw-input').focus();
  }
}
function goToOrder() { showPage('order'); }
function showPage(name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  window.scrollTo(0, 0);
}
 
/* ── Order form rendering ── */
function stockBadgeOrder(id) {
  const s = stock[id] !== undefined ? stock[id] : 999;
  if (s <= 0) return '<span class="out-badge">Out of stock</span>';
  if (s <= LOW_THRESH_DEFAULT) return '<span class="low-badge">Low stock</span>';
  return '';
}
 
function cardHTML(p, isNew) {
  const s = stock[p.id] !== undefined ? stock[p.id] : 999;
  const isOut = s <= 0;
  return `<div class="item-card ${qty[p.id] > 0 ? 'selected' : ''} ${isOut ? 'out-of-stock' : ''}" id="card-${p.id}">
    ${isNew ? '<span class="new-badge">New</span>' : ''}
    <span class="item-emoji">${p.emoji}</span>
    <p class="item-name">${p.name}</p>
    <p class="item-desc">${p.desc}</p>
    <p class="item-price">$${p.price.toFixed(2)}</p>
    ${stockBadgeOrder(p.id)}
    <div class="qty-ctrl">
      <button class="qty-btn" onclick="change('${p.id}',-1)" ${isOut ? 'disabled' : ''}>−</button>
      <span class="qty-num" id="qty-${p.id}">${qty[p.id]}</span>
      <button class="qty-btn" onclick="change('${p.id}',1)" ${isOut ? 'disabled' : ''}>+</button>
    </div>
  </div>`;
}
 
function renderOrderForm() {
  document.getElementById('new-arrivals').innerHTML = NEW_ARRIVALS.map(p => cardHTML(p, true)).join('');
  const sorted = [...BRANDS].sort((a,b) => a.brand.localeCompare(b.brand));
  document.getElementById('brand-catalog').innerHTML = sorted.map(b =>
    `<div class="brand-block"><p class="brand-title">${b.brand}</p><div class="brand-grid">${b.products.map(p => cardHTML(p, false)).join('')}</div></div>`
  ).join('');
}
 
function change(id, delta) {
  const s = stock[id] !== undefined ? stock[id] : 999;
  if (s <= 0) return;
  qty[id] = Math.max(0, Math.min(s, qty[id] + delta));
  document.querySelectorAll('#qty-' + id).forEach(el => el.textContent = qty[id]);
  document.querySelectorAll('#card-' + id).forEach(el => el.classList.toggle('selected', qty[id] > 0));
  renderSummary();
}
 
function selectDelivery(method) {
  deliveryMethod = method;
  document.querySelectorAll('[data-delivery]').forEach(el => el.classList.toggle('selected', el.dataset.delivery === method));
  document.getElementById('address-field').style.display = method === 'delivery' ? '' : 'none';
  renderSummary();
}
 
function selectPayment(method) {
  paymentMethod = method;
  document.querySelectorAll('[data-pay]').forEach(el => el.classList.toggle('selected', el.dataset.pay === method));
}
 
function getSubtotal() {
  return ALL_PRODUCTS.reduce((sum, p) => sum + p.price * qty[p.id], 0);
}
 
function renderSummary() {
  const subtotal = getSubtotal();
  const lines = document.getElementById('summary-lines');
  const totalRow = document.getElementById('total-row');
  const feeRow = document.getElementById('delivery-fee-row');
  const notice = document.getElementById('delivery-notice');
  const items = ALL_PRODUCTS.filter(p => qty[p.id] > 0);
 
  if (!items.length) {
    lines.innerHTML = '<p class="empty-note">No items selected yet.</p>';
    totalRow.style.display = 'none';
    feeRow.style.display = 'none';
    notice.className = 'delivery-notice hidden';
    document.getElementById('wa-btn').disabled = true;
    return;
  }
 
  lines.innerHTML = items.map(p => {
    const sub = p.price * qty[p.id];
    return `<div class="summary-row"><span>${p.emoji} ${p.name} × ${qty[p.id]}</span><span>$${sub.toFixed(2)}</span></div>`;
  }).join('');
 
  let deliveryCharge = 0;
  if (deliveryMethod === 'delivery') {
    const isFree = subtotal >= FREE_THRESHOLD;
    deliveryCharge = isFree ? 0 : DELIVERY_FEE;
    const remaining = (FREE_THRESHOLD - subtotal).toFixed(2);
    const pct = Math.min(100, Math.round((subtotal / FREE_THRESHOLD) * 100));
    if (isFree) {
      feeRow.className = 'summary-row free-delivery';
      feeRow.innerHTML = `<span>Delivery</span><span>Free</span>`;
      notice.className = 'delivery-notice free';
      document.getElementById('notice-dot').className = 'dot green';
      document.getElementById('notice-text').textContent = "You've unlocked free delivery!";
    } else {
      feeRow.className = 'summary-row muted';
      feeRow.innerHTML = `<span>Delivery fee</span><span>$${DELIVERY_FEE.toFixed(2)}</span>`;
      notice.className = 'delivery-notice paid';
      document.getElementById('notice-dot').className = 'dot orange';
      document.getElementById('notice-text').innerHTML =
        `Add $${remaining} more for free delivery<div class="progress-bar-wrap"><div class="progress-bar" style="width:${pct}%"></div></div>`;
    }
    feeRow.style.display = 'flex';
  } else {
    feeRow.style.display = 'none';
    notice.className = 'delivery-notice hidden';
  }
 
  const total = subtotal + deliveryCharge;
  totalRow.style.display = 'flex';
  document.getElementById('total-amount').textContent = '$' + total.toFixed(2);
  document.getElementById('wa-btn').disabled = false;
}
 
const payLabels = { paynow: 'PayNow', cash: 'Cash on delivery', transfer: 'Bank transfer', grabpay: 'GrabPay' };
const deliveryLabels = { delivery: 'Delivery', pickup: 'Self-pickup' };
 
document.getElementById('wa-btn').addEventListener('click', () => {
  const name = document.getElementById('f-name').value.trim() || '(not provided)';
  const phone = document.getElementById('f-phone').value.trim();
  const fullPhone = phone ? '+65 ' + phone : '(not provided)';
  const address = document.getElementById('f-address').value.trim() || '(not provided)';
  const notes = document.getElementById('f-notes').value.trim();
  const items = ALL_PRODUCTS.filter(p => qty[p.id] > 0);
  const subtotal = getSubtotal();
  const isFreeDelivery = deliveryMethod === 'delivery' && subtotal >= FREE_THRESHOLD;
  const deliveryCharge = deliveryMethod === 'delivery' && !isFreeDelivery ? DELIVERY_FEE : 0;
  const total = subtotal + deliveryCharge;
 
  items.forEach(p => { stock[p.id] = Math.max(0, (stock[p.id] || 0) - qty[p.id]); });
  saveStock();
 
  let msg = `🛒 *New Order*\n\n*Name:* ${name}\n*Phone:* ${fullPhone}\n`;
  if (deliveryMethod === 'delivery') msg += `*Address:* ${address}\n`;
  msg += `*Delivery:* ${deliveryLabels[deliveryMethod]}\n*Payment:* ${payLabels[paymentMethod]}\n`;
  if (notes) msg += `*Notes:* ${notes}\n`;
  msg += `\n*Items:*\n${items.map(p => `  ${p.emoji} ${p.name} x${qty[p.id]} — $${(p.price*qty[p.id]).toFixed(2)}`).join('\n')}\n`;
  if (deliveryMethod === 'delivery') msg += `\nDelivery: ${isFreeDelivery ? 'Free' : '$' + DELIVERY_FEE.toFixed(2)}`;
  msg += `\n*Total: $${total.toFixed(2)}*`;
 
  window.open(`https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(msg)}`, '_blank');
});
 
document.getElementById('f-phone').addEventListener('input', function() {
  this.value = this.value.replace(/\D/g, '').slice(0, 8);
});
 
/* ── Admin panel rendering ── */
function adminBadgeHTML(qty) {
  const t = getThresh();
  if (qty <= 0) return '<span class="stock-badge badge-out">Out of stock</span>';
  if (qty <= t) return '<span class="stock-badge badge-low">Low stock</span>';
  return '<span class="stock-badge badge-ok">In stock</span>';
}
 
function productRowHTML(p) {
  const q = stock[p.id] !== undefined ? stock[p.id] : 20;
  return `<div class="product-row">
    <span class="prod-emoji">${p.emoji}</span>
    <div class="prod-info">
      <p class="prod-name">${p.name}</p>
      <p class="prod-price">$${p.price.toFixed(2)}</p>
    </div>
    <div class="stock-ctrl">
      <input class="stock-input" type="number" min="0" max="999" value="${q}" id="input-${p.id}" onchange="onStockChange('${p.id}')">
      <span id="abadge-${p.id}">${adminBadgeHTML(q)}</span>
    </div>
  </div>`;
}
 
function onStockChange(id) {
  const val = Math.max(0, parseInt(document.getElementById('input-' + id).value) || 0);
  document.getElementById('input-' + id).value = val;
  stock[id] = val;
  document.getElementById('abadge-' + id).innerHTML = adminBadgeHTML(val);
  updateStats();
}
 
function renderAdmin() {
  document.getElementById('admin-new').innerHTML =
    '<p class="admin-brand-name" style="margin-bottom:6px;">New arrivals</p>' +
    NEW_ARRIVALS.map(p => productRowHTML(p)).join('');
  const sorted = [...BRANDS].sort((a,b) => a.brand.localeCompare(b.brand));
  document.getElementById('admin-brands').innerHTML = sorted.map(b =>
    `<div class="admin-brand-block"><p class="admin-brand-name">${b.brand}</p>${b.products.map(p => productRowHTML(p)).join('')}</div>`
  ).join('');
  updateStats();
}
 
function updateStats() {
  const t = getThresh();
  let low = 0, out = 0;
  ALL_PRODUCTS.forEach(p => {
    const q = stock[p.id] || 0;
    if (q <= 0) out++;
    else if (q <= t) low++;
  });
  document.getElementById('stat-total').textContent = ALL_PRODUCTS.length;
  document.getElementById('stat-low').textContent = low;
  document.getElementById('stat-out').textContent = out;
}
 
function saveAll() {
  ALL_PRODUCTS.forEach(p => {
    const el = document.getElementById('input-' + p.id);
    if (el) stock[p.id] = Math.max(0, parseInt(el.value) || 0);
  });
  saveStock();
  renderOrderForm();
  const t = document.getElementById('toast');
  t.textContent = 'Saved!';
  t.style.display = 'inline-block';
  setTimeout(() => t.style.display = 'none', 2000);
}
 
/* ── Init ── */
loadStock();
renderOrderForm();
renderSummary();
</script>
</body>
</html>
