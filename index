<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Inventory Admin Panel</title>
<style>
  :root { --accent: #D85A30; --accent-bg: #FAECE7; --accent-text: #993C1D; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f9f9f8; color: #1a1a1a; padding: 2rem; }
  .wrap { max-width: 720px; margin: 0 auto; }
  .topbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 10px; }
  .topbar h2 { font-size: 20px; font-weight: 500; }
  .stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 1.5rem; }
  .stat { background: #f1efe8; border-radius: 8px; padding: 12px 14px; }
  .stat-label { font-size: 12px; color: #888780; margin-bottom: 4px; }
  .stat-val { font-size: 22px; font-weight: 500; }
  .stat-val.warn { color: #854F0B; }
  .stat-val.danger { color: #A32D2D; }
  .section-label { font-size: 11px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: #888780; margin: 0 0 10px; }
  .brand-block { margin-bottom: 1.5rem; }
  .brand-name { font-size: 13px; font-weight: 500; color: #5F5E5A; padding: 5px 0; border-bottom: 0.5px solid rgba(0,0,0,0.12); margin-bottom: 8px; }
  .product-row { display: flex; align-items: center; gap: 10px; padding: 8px 0; border-bottom: 0.5px solid rgba(0,0,0,0.08); flex-wrap: wrap; }
  .product-row:last-child { border-bottom: none; }
  .prod-emoji { font-size: 16px; flex-shrink: 0; }
  .prod-info { flex: 1; min-width: 120px; }
  .prod-name { font-size: 13px; font-weight: 500; }
  .prod-price { font-size: 12px; color: #888780; }
  .stock-ctrl { display: flex; align-items: center; gap: 6px; }
  .stock-input { width: 60px; font-size: 13px; padding: 5px 8px; border: 0.5px solid rgba(0,0,0,0.2); border-radius: 8px; background: #fff; color: #1a1a1a; text-align: center; font-family: inherit; }
  .stock-badge { font-size: 11px; padding: 2px 8px; border-radius: 20px; font-weight: 500; white-space: nowrap; }
  .badge-ok { background: #EAF3DE; color: #27500A; }
  .badge-low { background: #FAEEDA; color: #633806; }
  .badge-out { background: #FCEBEB; color: #791F1F; }
  .save-all-btn { font-size: 13px; padding: 9px 18px; border: 0.5px solid rgba(0,0,0,0.2); border-radius: 8px; background: #fff; color: #1a1a1a; cursor: pointer; font-family: inherit; }
  .save-all-btn:hover { background: #f1efe8; }
  .toast { font-size: 13px; padding: 8px 14px; background: #f1efe8; border: 0.5px solid rgba(0,0,0,0.15); border-radius: 8px; color: #5F5E5A; display: none; }
  .low-thresh { display: flex; align-items: center; gap: 8px; margin-bottom: 1.5rem; flex-wrap: wrap; }
  .low-thresh label { font-size: 13px; color: #5F5E5A; }
  .low-thresh input { width: 60px; font-size: 13px; padding: 5px 8px; border: 0.5px solid rgba(0,0,0,0.2); border-radius: 8px; background: #fff; color: #1a1a1a; text-align: center; font-family: inherit; }
  .new-section { background: #f1efe8; border-radius: 8px; padding: 2px 8px; margin-bottom: 1.5rem; }
  .new-section .brand-name { font-size: 12px; color: #888780; }
</style>
</head>
<body>
<div class="wrap">
  <div class="topbar">
    <h2>Inventory admin</h2>
    <div style="display:flex;gap:8px;align-items:center;">
      <span class="toast" id="toast">Saved!</span>
      <button class="save-all-btn" onclick="saveAll()">Save all changes</button>
    </div>
  </div>
 
  <div class="stats">
    <div class="stat"><p class="stat-label">Total products</p><p class="stat-val" id="stat-total">—</p></div>
    <div class="stat"><p class="stat-label">Low stock</p><p class="stat-val warn" id="stat-low">—</p></div>
    <div class="stat"><p class="stat-label">Out of stock</p><p class="stat-val danger" id="stat-out">—</p></div>
  </div>
 
  <div style="display:flex;align-items:center;gap:12px;margin-bottom:1.5rem;flex-wrap:wrap;">
    <p class="section-label" style="margin:0;">Low stock threshold</p>
    <div class="low-thresh" style="margin:0;">
      <label>Flag as low when stock ≤</label>
      <input type="number" id="low-thresh" value="5" min="1" max="50" onchange="renderAll()">
      <span style="font-size:13px;color:#5F5E5A;">units</span>
    </div>
  </div>
 
  <p class="section-label">New arrivals</p>
  <div class="new-section" id="admin-new"></div>
 
  <p class="section-label">Product selection</p>
  <div id="admin-brands"></div>
</div>
 
<script>
const NEW_ARRIVALS = [
  { id: 'n1', emoji: '🍬', name: 'Placeholder Drop A', price: 3.50 },
  { id: 'n2', emoji: '🍫', name: 'Placeholder Drop B', price: 4.00 },
  { id: 'n3', emoji: '🍭', name: 'Placeholder Drop C', price: 3.00 },
];
const BRANDS = [
  { brand: 'Airheads', products: [
    { id: 'a1', emoji: '🍬', name: 'Airheads Bars', price: 2.50 },
    { id: 'a2', emoji: '🍡', name: 'Airheads Bites', price: 3.00 },
  ]},
  { brand: 'Nerds', products: [
    { id: 'nb1', emoji: '🍇', name: 'Nerds Grape & Strawberry', price: 2.80 },
    { id: 'nb2', emoji: '🌈', name: 'Nerds Rope Rainbow', price: 3.20 },
  ]},
];
const ALL_PRODUCTS = [...NEW_ARRIVALS, ...BRANDS.flatMap(b => b.products)];
let stock = {};
 
function loadStock() {
  try {
    const saved = localStorage.getItem('inventory-stock');
    stock = saved ? JSON.parse(saved) : {};
  } catch(e) { stock = {}; }
  ALL_PRODUCTS.forEach(p => { if (stock[p.id] === undefined) stock[p.id] = 20; });
  renderAll();
}
 
function getThresh() { return parseInt(document.getElementById('low-thresh').value) || 5; }
 
function badgeHTML(qty) {
  if (qty <= 0) return '<span class="stock-badge badge-out">Out of stock</span>';
  if (qty <= getThresh()) return '<span class="stock-badge badge-low">Low stock</span>';
  return '<span class="stock-badge badge-ok">In stock</span>';
}
 
function productRowHTML(p) {
  const q = stock[p.id] !== undefined ? stock[p.id] : 20;
  return `<div class="product-row" id="row-${p.id}">
    <span class="prod-emoji">${p.emoji}</span>
    <div class="prod-info">
      <p class="prod-name">${p.name}</p>
      <p class="prod-price">$${p.price.toFixed(2)}</p>
    </div>
    <div class="stock-ctrl">
      <input class="stock-input" type="number" min="0" max="999" value="${q}" id="input-${p.id}" onchange="onStockChange('${p.id}')">
      <span id="badge-${p.id}">${badgeHTML(q)}</span>
    </div>
  </div>`;
}
 
function onStockChange(id) {
  const val = Math.max(0, parseInt(document.getElementById('input-' + id).value) || 0);
  document.getElementById('input-' + id).value = val;
  stock[id] = val;
  document.getElementById('badge-' + id).innerHTML = badgeHTML(val);
  updateStats();
}
 
function renderAll() {
  document.getElementById('admin-new').innerHTML =
    '<div class="brand-name">New arrivals</div>' +
    NEW_ARRIVALS.map(p => productRowHTML(p)).join('');
  const sorted = [...BRANDS].sort((a,b) => a.brand.localeCompare(b.brand));
  document.getElementById('admin-brands').innerHTML = sorted.map(b =>
    `<div class="brand-block"><p class="brand-name">${b.brand}</p>${b.products.map(p => productRowHTML(p)).join('')}</div>`
  ).join('');
  updateStats();
}
 
function updateStats() {
  const thresh = getThresh();
  let low = 0, out = 0;
  ALL_PRODUCTS.forEach(p => {
    const q = stock[p.id] || 0;
    if (q <= 0) out++;
    else if (q <= thresh) low++;
  });
  document.getElementById('stat-total').textContent = ALL_PRODUCTS.length;
  document.getElementById('stat-low').textContent = low;
  document.getElementById('stat-out').textContent = out;
}
 
function saveAll() {
  ALL_PRODUCTS.forEach(p => {
    const el = document.getElementById('input-' + p.id);
    if (el) stock[p.id] = Math.max(0, parseInt(el.value) || 0);
  });
  try {
    localStorage.setItem('inventory-stock', JSON.stringify(stock));
    const t = document.getElementById('toast');
    t.textContent = 'Saved!';
    t.style.display = 'inline-block';
    setTimeout(() => t.style.display = 'none', 2000);
  } catch(e) {
    const t = document.getElementById('toast');
    t.textContent = 'Save failed';
    t.style.display = 'inline-block';
    setTimeout(() => t.style.display = 'none', 2000);
  }
}
 
loadStock();
</script>
</body>
</html>
